# Copy to .env and fill in real values. Never commit .env.

# LLM (Deep Agent backend)
TRACE_AGENT_MODEL_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=120

# Trace engine
TRACE_AGENT_ALLOW_PRODUCTION=0
TRACE_AGENT_ENGINE_CONFIG=configs/engine.yaml
TRACE_ENGINE_DEMO_PROFILE=0
TRACE_ENGINE_MODEL_PLANNER_MODE=shadow
TRACE_ENGINE_MODEL_JUDGEMENT_MODE=assist
TRACE_ENGINE_MODEL_MCP_COMPILER_MODE=shadow

# Optional threat-intel keys (offline prior / enricher)
VT_API_KEY=
THREATBOOK_API_KEY=

# Production MCP (see host-client.env.example + HOST_CLIENT_HANDOFF.md)
TRACE_ENGINE_MCP_ENDPOINT=
MCP_API_KEY=
WAZUH_MCP_TOKEN=
