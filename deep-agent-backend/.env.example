# Model configuration. Keep real keys outside source control.
TRACE_AGENT_MODEL_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=120

# Scenario mode is the safe default. Production access requires both values.
TRACE_AGENT_ALLOW_PRODUCTION=0
TRACE_AGENT_ENGINE_CONFIG=../configs/engine.yaml

